{
  "name": "dalla-backend",
  "version": "4.1.0",
  "description": "دلّة ☕ — Production Backend",
  "main": "server.js",
  "scripts": {
    "start": "pm2-runtime start ecosystem.config.js --env production",
    "start:dev": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "node db/init.js",
    "test": "jest --testTimeout=10000 --forceExit",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "pm2": "^5.4.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  }
}
